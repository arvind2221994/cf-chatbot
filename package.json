{
  "name": "cf-chatbot",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rimraf dist .wrangler node_modules/.vite .vercel",
    "reset": "npm run clean && npm install",
    "pages:dev": "wrangler pages dev dist --proxy 5173",
    "pages:deploy": "npm run build && wrangler pages deploy dist"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@google/generative-ai": "^0.24.1",
    "@mui/material": "^7.3.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240403.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "rimraf": "^6.1.2",
    "vite": "^5.2.8",
    "wrangler": "^3.22.5"
  }
}
